# LLM / search provider keys (set at least one you use)
NVIDIA_API_KEY=
OPENAI_API_KEY=
CEREBRAS_API_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=

# Auth — change JWT_SECRET and ADMIN_PASSWORD before going live
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@labcd.ai
ADMIN_PASSWORD=change-me-strong-password

# CORS — production origins for labcd.ai
CORS_ORIGINS=https://labcd.ai,https://www.labcd.ai

# PostgreSQL — change POSTGRES_PASSWORD before going live
POSTGRES_USER=labcd
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=labcd

# Paths inside containers (compose also sets these for the api service)
RESULTS_DIR=/app/results
UPLOADS_DIR=/app/uploads

# DATABASE_URL is overridden in docker-compose.prod.yml for the api service.
# Optional local reference:
# DATABASE_URL=postgresql+psycopg://labcd:PASSWORD@db:5432/labcd
