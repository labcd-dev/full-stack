# LLM / search provider keys (set at least one you use)
NVIDIA_API_KEY=
OPENAI_API_KEY=
CEREBRAS_API_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=

# FastAPI backend
API_PORT=8000
FRONTEND_PORT=5173
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RESULTS_DIR=results
UPLOADS_DIR=uploads

# PostgreSQL
POSTGRES_USER=labcd
POSTGRES_PASSWORD=labcd
POSTGRES_DB=labcd
POSTGRES_PORT=5432
# Local (API on host): use localhost. Docker Compose overrides this for the api service.
DATABASE_URL=postgresql+psycopg://labcd:labcd@localhost:5432/labcd

# Auth (change JWT_SECRET and ADMIN_PASSWORD in production)
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
