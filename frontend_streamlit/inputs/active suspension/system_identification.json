{"system_name":"Mass-Spring-Damper System with Uncontrolled Mass","description":"A system with two masses (zs, zu) connected by a spring (ks) and damper (bs), where zs is directly driven by an input force (u) and zu is influenced by an additional damping force (kt*zu), controlled by applying a force u to the first mass.","system_properties":{"continuous":"Continuous","linear":"Linear","order":4,"type":"SISO"},"inputs":[{"physical_meaning":"Force applied to the first mass (zs)","variable_name":"Force Input","variable_in_equation":"u","unit":"N (Newtons)"}],"outputs":[{"physical_meaning":"Position of the first mass","variable_in_equation":"x[0]","unit":"m (Meters)"},{"physical_meaning":"Velocity of the first mass","variable_in_equation":"x[1]","unit":"m/s (Meters per Second)"},{"physical_meaning":"Position of the second mass","variable_in_equation":"x[2]","unit":"m (Meters)"},{"physical_meaning":"Velocity of the second mass","variable_in_equation":"x[3]","unit":"m/s (Meters per Second)"}],"state_variables":[{"physical_meaning":"Position of the first mass (zs)","variable_name":"zs","variable_in_equation":"x[0]","unit":"m (Meters)"},{"physical_meaning":"Velocity of the first mass (vs)","variable_name":"vs","variable_in_equation":"x[1]","unit":"m/s (Meters per Second)"},{"physical_meaning":"Position of the second mass (zu)","variable_name":"zu","variable_in_equation":"x[2]","unit":"m (Meters)"},{"physical_meaning":"Velocity of the second mass (vu)","variable_name":"vu","variable_in_equation":"x[3]","unit":"m/s (Meters per Second)"}]}